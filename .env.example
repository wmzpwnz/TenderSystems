# ============================================
# TenderSystems - Переменные окружения
# ============================================
# 
# ИНСТРУКЦИЯ:
# 1. Скопируйте этот файл: cp .env.example .env
# 2. Заполните все значения реальными данными
# 3. НИКОГДА не коммитьте .env файл в Git!
#
# ============================================

# ============================================
# БАЗА ДАННЫХ
# ============================================
# PostgreSQL connection string
# Формат: postgresql://user:password@host:port/database
# ВАЖНО: Смените пароль на сильный!
DATABASE_URL=postgresql://tenderuser:CHANGE_THIS_PASSWORD@postgres:5432/tenderdb

# Пароль для PostgreSQL (используется в docker-compose.yml)
# ⚠️  ОБЯЗАТЕЛЬНО СГЕНЕРИРУЙТЕ: openssl rand -base64 32
DB_PASSWORD=<СГЕНЕРИРУЙТЕ_КОМАНДОЙ_openssl_rand_-base64_32>

# ============================================
# REDIS
# ============================================
# Redis connection URL
# По умолчанию используется встроенный Redis из docker-compose
REDIS_URL=redis://redis:6379/0

# ============================================
# БЕЗОПАСНОСТЬ
# ============================================
# JWT Secret Key (обязательно!)
# ⚠️  ОБЯЗАТЕЛЬНО СГЕНЕРИРУЙТЕ: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Должен быть минимум 32 символа!
SECRET_KEY=<СГЕНЕРИРУЙТЕ_КОМАНДОЙ_python3_-c_import_secrets_print_secrets_token_urlsafe_32>

# Режим отладки
# В production ДОЛЖНО быть False!
DEBUG=False

# Разрешенные CORS origins (через запятую)
# Для development:
# ALLOWED_ORIGINS=http://localhost:3002,http://localhost:8003
# Для production укажите ваш домен:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:8003,http://127.0.0.1:3002,http://127.0.0.1:8003

# ============================================
# DEEPSEEK AI API
# ============================================
# API ключ от DeepSeek (обязательно для AI анализа)
# Получите на: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_API_KEY_HERE

# URL API DeepSeek (обычно не нужно менять)
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ============================================
# ЕИС (Единая Информационная Система)
# ============================================
# SOAP API токен (обязательно для работы с ЕИС)
# Получите через Госуслуги: https://zakupki.gov.ru/
EIS_SOAP_TOKEN=YOUR_EIS_SOAP_TOKEN_HERE

# Использовать SOAP API (рекомендуется)
EIS_USE_SOAP=true

# ⚠️  FTP СЕРВЕР ЗАКРЫТ С 01.01.2025 - НЕ ИСПОЛЬЗУЙТЕ!
EIS_USE_FTP=false

# Использовать HTML парсинг (fallback метод, рекомендуется включить)
EIS_USE_HTML_PARSING=true

# Использовать Mobile API (обычно не нужно)
EIS_USE_MOBILE_API=false

# FTP настройки (обычно не нужно менять)
EIS_FTP_HOST=ftp.zakupki.gov.ru
EIS_FTP_USER=anonymous
EIS_FTP_PASSWORD=

# API ключ ЕИС (если используется Mobile API)
EIS_API_KEY=

# Пути к сертификатам (если используется клиентский сертификат)
EIS_CERT_PATH=
EIS_KEY_PATH=

# Базовый URL ЕИС (обычно не нужно менять)
EIS_BASE_URL=https://zakupki.gov.ru/epz/order/extendedsearch/results.html
EIS_API_URL=https://zakupki.gov.ru/epz/api/mobile/proxy

# ============================================
# ФАЙЛЫ
# ============================================
# Максимальный размер загружаемого файла (в байтах)
# По умолчанию: 10MB
MAX_UPLOAD_SIZE=10485760

# Директория для загрузок
UPLOAD_DIR=./uploads
